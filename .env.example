# Másold .env néven, és töltsd ki a saját értékeiddel.

# PostgreSQL
POSTGRES_DB=tarokk
POSTGRES_USER=tarokk
POSTGRES_PASSWORD=valami-eros-jelszo

# JWT – Base64-kódolt titok. Generálás:  openssl rand -base64 48
JWT_SECRET=cseréld-le-egy-base64-titokra

# Visszajelzés (hibajelentés / javaslat) e-mailben. Ha üresen hagyod, a
# funkció nem küld levelet (a kérés hibát ad vissza). Gmailnél kapcsold be a
# 2FA-t, és generálj App password-öt: https://myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=sajat.cimed@gmail.com
MAIL_PASSWORD=gmail-app-jelszo
# Ide érkeznek a visszajelzések. Üresen hagyva a MAIL_USERNAME címre megy.
FEEDBACK_TO=sajat.cimed@gmail.com

# --- Csak éles (production) deployhoz, a docker-compose.prod.yml-hez ---
# A domain, amin a játék elérhető lesz (pl. duckdns aldomain).
DOMAIN=tarokk-valami.duckdns.org
# E-mail a Let's Encrypt tanúsítványhoz (értesítések ide jönnek).
ACME_EMAIL=te@example.com
