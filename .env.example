# Másold .env néven, és töltsd ki a saját értékeiddel.

# PostgreSQL
POSTGRES_DB=tarokk
POSTGRES_USER=tarokk
POSTGRES_PASSWORD=valami-eros-jelszo

# JWT – Base64-kódolt titok. Generálás:  openssl rand -base64 48
JWT_SECRET=cseréld-le-egy-base64-titokra

# --- Csak éles (production) deployhoz, a docker-compose.prod.yml-hez ---
# A domain, amin a játék elérhető lesz (pl. duckdns aldomain).
DOMAIN=tarokk-valami.duckdns.org
# E-mail a Let's Encrypt tanúsítványhoz (értesítések ide jönnek).
ACME_EMAIL=te@example.com
